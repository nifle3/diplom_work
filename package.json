{
	"name": "diplom_work",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"test": "turbo run test",
		"test:coverage": "turbo run test:coverage",
		"dev": "turbo run dev",
		"build": "turbo run build",
		"start": "turbo run start",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev --filter=web",
		"db:push": "turbo run db:push --filter=@diplom_work/db",
		"db:studio": "turbo run db:studio --filter=@diplom_work/db",
		"db:generate": "turbo run db:generate --filter=@diplom_work/db",
		"db:generate-custom": "turbo run db:generate-custom --filter=@diplom_work/db",
		"db:migrate": "turbo run db:migrate --filter=@diplom_work/db",
		"db:start": "turbo run db:start --filter=@diplom_work/db",
		"db:watch": "turbo run db:watch --filter=@diplom_work/db",
		"db:stop": "turbo run db:stop --filter=@diplom_work/db",
		"db:down": "turbo run db:down --filter=@diplom_work/db",
		"lint": "biome check --write ."
	},
	"dependencies": {
		"@diplom_work/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@diplom_work/config": "workspace:*",
		"@types/node": "^22.13.14",
		"turbo": "^2.6.3",
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.27.0"
}
