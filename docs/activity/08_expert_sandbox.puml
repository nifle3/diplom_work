@startuml 08_expert_sandbox
title Тестирование скрипта в песочнице эксперта
skinparam ActivityBackgroundColor White

start

partition "Создание сессии" {
  :Эксперт передаёт scriptId;

  if (Эксперт владеет скриптом?) then (нет)
    :Ошибка FORBIDDEN;
    stop
  endif

  :Создать сессию и первый вопрос;
  :Вернуть sessionId;
}

partition "Отправка ответа" {
  :Эксперт отправляет ответ;

  :LLM: суммаризация, оценка ответа,\n  планирование следующего шага;

  if (decision == "finish"?) then (да)
    :LLM: итоговая оценка сессии;
    :Вернуть {type: "finished"};
    stop
  else (нет)
    :Сохранить ответ и следующий вопрос;
    :Вернуть {type: "next-question", analysisNote};
  endif
}

partition "Перемотка (rewind)" {
  :Эксперт выбирает сообщение\nдля возврата;

  if (Сообщение = ответ эксперта?) then (нет)
    :Ошибка (нельзя перемотать);
    stop
  endif

  :Удалить последующие сообщения;
  :Пересобрать резюме диалога;
  :Обновить сессию в БД;
  :Вернуть обновлённое состояние;
}

stop
@enduml
