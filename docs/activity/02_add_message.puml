@startuml 02_add_message
title Обработка ответа пользователя в интервью
skinparam ActivityBackgroundColor White

start

:Пользователь отправляет ответ\n(sessionId, content);

:Загрузить активную сессию\n(принадлежащую пользователю);

if (Сессия найдена и активна?) then (нет)
  :Ошибка NOT_FOUND / BAD_REQUEST;
  stop
endif

:LLM: обновить резюме диалога;

:LLM: оценить ответ\n→ score, feedback, analysisNote;

:LLM: планировать следующий шаг\n→ follow_up | next_topic | finish;

:Сохранить сообщение пользователя в БД;

if (decision == "finish"?) then (да)
  :Завершить сессию (finalize);
  :Вернуть {type: "finished", result};
  stop
else (нет)
  if (decision == "follow_up"?) then (да)
    :Следующий вопрос от LLM;
  else (next_topic)
    :Следующий вопрос из скрипта;
  endif

  :Сохранить следующий вопрос AI в БД;
  :Вернуть {type: "next-question", message};
  stop
endif

@enduml
