@startuml 02_add_message
title Обработка ответа пользователя в интервью

start

:Пользователь отправляет ответ\n(sessionId, content);

:Загрузить сессию со всеми\nсвязями (сообщения, скрипт,\nстатус, критерии);

if (Сессия найдена\nи принадлежит пользователю?) then (нет)
  :Выбросить ошибку NOT_FOUND;
  stop
endif

if (Статус сессии = "active"?) then (нет)
  :Выбросить ошибку\n(сессия не активна);
  stop
endif

:Получить последнее сообщение AI\n(текущий вопрос);

partition "LLM: Суммаризация" {
  :Вызвать LLM.summarize(\n  humanResponse,\n  aiQuestion,\n  prevSummarization\n);
  :Получить обновлённое резюме;
}

partition "LLM: Оценка ответа" {
  :Вызвать LLM.evaluateAnswer(\n  mode = "answer",\n  context, question, answer,\n  globalCriteria, specificCriteria\n);
  :Получить: score, feedback,\n  analysisNote, strengths,\n  improvements;
}

partition "LLM: Планирование шага" {
  :Вызвать LLM.planInterviewStep(\n  context, summary,\n  currentTopic, nextTopic,\n  criteria, latestQ&A\n);
  :Получить decision:\n  "follow_up" | "next_topic" | "finish";
}

:Открыть транзакцию БД;

:Обновить поле summarize в сессии;

:Вставить сообщение пользователя\n(с analysisNote);

if (decision == "finish"?) then (да)
  :Вызвать finalizeSession();
  note right
    Завершение: оценка всей сессии,
    начисление XP и ачивок
  end note
  :Зафиксировать транзакцию;
  :Вернуть {type: "finished", result};
  stop
else (нет)
  if (decision == "follow_up"?) then (да)
    :Использовать вопрос от LLM\nкак следующий;
  else (next_topic)
    :Взять следующий вопрос\nиз скрипта;
  endif

  :Вычислить nextQuestionIndex;
  :Обновить currentQuestionIndex в сессии;
  :Вставить следующее сообщение AI;
  :Зафиксировать транзакцию;
  :Вернуть {type: "next-question", message};
  stop
endif

@enduml
