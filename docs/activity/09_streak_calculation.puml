@startuml 09_streak_calculation
title Расчёт серии (streak) пользователя

start

:Загрузить все завершённые\nсессии пользователя\n(status = "complete");

if (Нет завершённых сессий?) then (да)
  :Вернуть streak = 0;
  stop
endif

:Извлечь уникальные UTC-дни\nиз дат завершения\n(формат YYYY-MM-DD);

:Отсортировать дни\nпо убыванию (DESC);

:Взять самый последний день;

if (Последний день = сегодня\nили вчера (UTC)?) then (нет)
  :Вернуть streak = 0;
  stop
endif

:Инициализировать streak = 1;
:Установить prevDay = последний день;

repeat
  :Взять следующий день из списка;

  if (День = prevDay - 1 день?) then (да)
    :streak = streak + 1;
    :prevDay = текущий день;
  else (нет)
    :Прервать — серия прервана;
  endif

repeat while (Ещё дни в списке?) is (да)
->нет;

:Вернуть streak;

stop
@enduml
