@startuml 09_streak_calculation
title Расчёт серии (streak) пользователя
skinparam ActivityBackgroundColor White

start

:Загрузить уникальные дни\nзавершённых сессий (UTC, DESC);

if (Нет завершённых сессий?) then (да)
  :Вернуть streak = 0;
  stop
endif

if (Последняя сессия была\nсегодня или вчера?) then (нет)
  :Вернуть streak = 0;
  stop
endif

:streak = 1;

repeat
  :Взять следующий день;
  if (Следует подряд?) then (да)
    :streak++;
  else (нет)
    :Прервать;
  endif
repeat while (Ещё дни?) is (да)
->нет;

:Вернуть streak;

stop
@enduml
