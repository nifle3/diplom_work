@startuml 10_llm_evaluate_answer
title LLM: Оценка ответа

start

:Получить входные данные\n(mode, context, criteria);

if (mode == "answer"?) then (да)
  :Сформировать промпт:\n  вопрос + ответ + критерии + резюме;
  :Ожидаемый вывод:\n  score, feedback, analysisNote,\n  strengths, improvements;
else (mode == "session")
  :Сформировать промпт:\n  полный диалог + критерии;
  :Ожидаемый вывод:\n  score, feedback, analysisNote,\n  strengths, improvements;
endif

:Запросить структурированный ответ у LLM;

if (Ответ валиден?) then (нет)
  :Ошибка парсинга;
  stop
endif

:Вернуть структурированную оценку;

stop
@enduml
