@startuml 01_create_session
title Создание новой сессии интервью

start

:Пользователь передаёт scriptId;

:Загрузить скрипт из БД\n(с вопросами и критериями);

if (Скрипт найден и не удалён?) then (нет)
  :Выбросить ошибку NOT_FOUND;
  stop
endif

if (Скрипт имеет контекст\nи хотя бы один вопрос?) then (нет)
  :Выбросить ошибку BAD_REQUEST;
  stop
endif

:Найти активную сессию\nпользователя по этому скрипту;

if (Активная сессия существует?) then (да)
  :Вернуть ID существующей сессии;
  stop
endif

:Сгенерировать UUID новой сессии;

:Открыть транзакцию БД;

:Вставить запись сессии\n(currentQuestionIndex = 0);

:Вставить лог статуса\n(status = "active");

:Вставить первое сообщение от AI\n(первый вопрос из скрипта);

:Зафиксировать транзакцию;

:Записать лог операции;

:Вернуть sessionId;

stop
@enduml
