@startuml 06_report_creation
title Создание жалобы на скрипт
skinparam ActivityBackgroundColor White

start

:Пользователь отправляет жалобу\n(scriptId, reason);

:Проверить наличие предыдущей жалобы;

if (Жалоба уже на рассмотрении?) then (да)
  :Вернуть ID существующей жалобы;
  stop
endif

if (Скрипт существует и доступен?) then (нет)
  :Ошибка NOT_FOUND;
  stop
endif

:Создать жалобу в БД\n(статус "new");

:Вернуть reportId;

stop
@enduml
