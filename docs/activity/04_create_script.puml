@startuml 04_create_script
title Создание скрипта (трёхшаговый мастер)
skinparam ActivityBackgroundColor White

start

:Эксперт начинает создание скрипта;

partition "Шаг 1: Основная информация" {
  :Ввести title, description,\n  image, categoryId;

  if (Валидация пройдена?) then (нет)
    :Показать ошибку валидации;
    stop
  endif

  :Сохранить черновик скрипта в БД;
}

partition "Шаг 2: Контекст и критерии" {
  :Ввести context, criteria[];
  :Сохранить контекст и критерии\n  (добавить / изменить / удалить);
}

partition "Шаг 3: Вопросы" {
  :Ввести questions[]\n  (порядок, текст, критерии);
  :Сохранить вопросы и критерии\n  (добавить / изменить / удалить);
  :Опубликовать скрипт (isDraft = false);
}

:Скрипт доступен для прохождения;

stop
@enduml
