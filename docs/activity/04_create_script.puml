@startuml 04_create_script
title Создание скрипта (трёхшаговый мастер)

start

:Эксперт начинает создание скрипта;

partition "Шаг 1: Основная информация" {
  :Ввести: title, description,\n  image, categoryId;
  :Валидация:\n  - title 5–50 символов\n  - description макс. 500\n  - категория существует;

  if (Валидация пройдена?) then (нет)
    :Показать ошибку валидации;
    stop
  endif

  :Вызвать mutateFirstStep();
  :Обновить поля скрипта в БД\n(скрипт остаётся черновиком);
}

partition "Шаг 2: Контекст и глобальные критерии" {
  :Ввести: context, criteria[]\n  (новые, изменённые, удалённые);
  :Вызвать mutateSecondStep();

  :Открыть транзакцию БД;
  :Обновить контекст скрипта;

  fork
    :INSERT новые критерии;
  fork again
    :UPDATE существующие критерии;
  fork again
    :Мягкое удаление удалённых\n(deletedAt = now());
  end fork

  :Зафиксировать транзакцию;
}

partition "Шаг 3: Вопросы и специфичные критерии" {
  :Ввести: questions[]\n  (порядок, текст, специфичные критерии);
  :Вызвать mutateThirdStep();

  :Открыть транзакцию БД;

  repeat
    :Взять следующий вопрос;

    if (Вопрос имеет ID?) then (да)
      :UPDATE: order, text;
    else (нет)
      :INSERT нового вопроса;\n:Получить новый ID;
    endif

    :Загрузить существующие\nспецифичные критерии вопроса;

    fork
      :DELETE отсутствующие критерии;
    fork again
      :UPDATE существующие критерии;
    fork again
      :INSERT новые критерии;
    end fork

  repeat while (Есть ещё вопросы?) is (да)
  ->нет;

  :Мягкое удаление удалённых\nвопросов (deletedAt = now());

  :Установить isDraft = false\n(публикация скрипта);

  :Зафиксировать транзакцию;
}

:Скрипт опубликован и доступен\nдля прохождения;

stop
@enduml
