@startuml 11_llm_plan_interview_step
title LLM: Планирование следующего шага интервью
skinparam ActivityBackgroundColor White

start

:Получить входные данные:\n  контекст, резюме, текущая тема,\n  последний Q&A, следующая тема;

:Сформировать промпт с вариантами:\n  follow_up | next_topic | finish;

:Запросить структурированный ответ у LLM\n→ decision + question;

if (decision == "follow_up"?) then (да)
  :Вернуть уточняющий вопрос\n  по текущей теме;
else if (decision == "next_topic"?) then (да)
  :Вернуть вводный вопрос\n  по следующей теме;
else (finish)
  :Вернуть decision = "finish";
endif

stop
@enduml
