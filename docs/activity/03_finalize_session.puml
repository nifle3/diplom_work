@startuml 03_finalize_session
title Завершение сессии интервью
skinparam ActivityBackgroundColor White

start

:Загрузить сессию;

if (Сессия уже завершена?) then (да)
  :Вернуть {complete: false};
  stop
endif

:LLM: итоговая оценка сессии\n→ finalScore, expertFeedback;

:Рассчитать experienceGained;

if (Режим = finalize?) then (да)
  :Сохранить статус "complete",\n  finalScore, expertFeedback;

  if (experienceGained > 0?) then (да)
    :Начислить XP пользователю;
  endif

  :Синхронизировать достижения;
  :Вернуть {complete: true, experienceGained};

else (cancel)
  :Сохранить статус "canceled",\n  finalScore, expertFeedback;
  :Вернуть {canceled: true};
endif

stop
@enduml
