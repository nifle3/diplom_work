@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam backgroundColor White
hide circle

title Auth Integration

package "Auth package" {
  class betterAuth <<library>> #White
  class auth <<instance>> #White
  class authSchema <<schema>> #White
  class drizzleAdapter <<adapter>> #White
  class nextCookies <<plugin>> #White
  class customSession <<plugin>> #White
  class createSendResetPassword <<factory>> #White
  class createLoggerBridge <<factory>> #White
  class createSessionHook <<factory>> #White
  class generateId <<factory>> #White
}

package "Database schema" {
  class usersTable <<table>> #White
  class sessionsTable <<table>> #White
  class verificationsTable <<table>> #White
  class accountsTable <<table>> #White
}

package "Support services" {
  class db <<instance>> #White
  class email <<service>> #White
  class env <<config>> #White
  class logger <<service>> #White
}

authSchema ..> usersTable
authSchema ..> sessionsTable
authSchema ..> verificationsTable
authSchema ..> accountsTable

auth ..> betterAuth
auth ..> drizzleAdapter
auth ..> nextCookies
auth ..> customSession
auth ..> createSendResetPassword
auth ..> createLoggerBridge
auth ..> createSessionHook
auth ..> generateId

drizzleAdapter ..> db
createSendResetPassword ..> email
createSendResetPassword ..> logger
createLoggerBridge ..> logger
createSessionHook ..> db
auth ..> env : trustedOrigins / secrets

@enduml
