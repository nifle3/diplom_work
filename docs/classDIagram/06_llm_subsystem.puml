@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide circle

title LLM Subsystem

package "Model setup" {
  class env <<config>> {
    +AI_KEY
  }

  class createMistral <<factory>> {
  }

  class generateText <<AI SDK>> {
  }

  class Output <<AI SDK>> {
  }

  class wrapLanguageModel <<adapter>> {
  }

  class shieldUserTextMiddleware <<middleware>> {
  }

  class model <<instance>> {
  }
}

package "Interviewer" {
  class outputScheme <<schema>> {
    +content: string
  }

  class generateTemplatePrompt <<function>> {
  }

  class getFirstQuestion <<function>> {
  }

  class getNextQuestion <<function>> {
  }

  class planInterviewStep <<function>> {
  }
}

package "Evaluation" {
  class evaluateAnswer <<function>> {
  }
}

package "Summarization" {
  class summarize <<function>> {
  }
}

package "Validation" {
  class zod <<library>> {
  }
}

createMistral ..> env
wrapLanguageModel ..> shieldUserTextMiddleware
model ..> createMistral
model ..> wrapLanguageModel
model ..> shieldUserTextMiddleware

getFirstQuestion ..> model
getFirstQuestion ..> generateText
getFirstQuestion ..> Output
getFirstQuestion ..> generateTemplatePrompt
getFirstQuestion ..> outputScheme
getNextQuestion ..> model
getNextQuestion ..> generateText
getNextQuestion ..> Output
getNextQuestion ..> generateTemplatePrompt
getNextQuestion ..> outputScheme
planInterviewStep ..> model
planInterviewStep ..> generateText
planInterviewStep ..> Output
planInterviewStep ..> zod
evaluateAnswer ..> model
evaluateAnswer ..> generateText
evaluateAnswer ..> Output
evaluateAnswer ..> zod
summarize ..> model
summarize ..> generateText
summarize ..> Output
summarize ..> zod

@enduml
