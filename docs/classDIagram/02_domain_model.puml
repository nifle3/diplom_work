@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam backgroundColor White
hide circle

title Domain Model

package "Errors" {
  class DomainError<T> <<abstract>> #White {
    +payload?: T
    +message: string
  }

  class StorageError <<error>> #White {
  }

  class FileTooLargeError <<error>> #White {
  }

  class EmailConfigurationError <<error>> #White {
  }

  class EmailDeliveryError <<error>> #White {
  }
}

package "Values" {
  enum Status {
    active
    complete
    canceled
  }

  class statusToId <<const map>> #White {
    +active: 1
    +complete: 2
    +canceled: 3
  }

  class reportStatuses <<const tuple>> #White {
    new
    in_review
    resolved
    rejected
  }

  class ReportStatus <<type alias>> #White {
  }
}

DomainError <|-- StorageError
DomainError <|-- FileTooLargeError
DomainError <|-- EmailConfigurationError
DomainError <|-- EmailDeliveryError

Status ..> statusToId : mapped by
reportStatuses ..> ReportStatus : source tuple
@enduml
