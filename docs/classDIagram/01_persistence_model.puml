@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam backgroundColor White
hide circle

title Persistence Model

package "Auth" {
  class rolesTable <<table>> #White {
    +id: integer
    +name: varchar(50)
  }

  class usersTable <<table>> #White {
    +id: uuid
    +name: text
    +email: text
    +emailVerified: boolean
    +roleId: integer
    +xp: integer
    +deletedAt: timestamp?
  }

  class accountsTable <<table>> #White {
    +id: uuid
    +accountId: uuid
    +providerId: text
    +userId: uuid
    +password: text?
  }

  class sessionsTable <<table>> #White {
    +id: uuid
    +token: text
    +expiresAt: timestamp
    +userId: uuid
  }

  class verificationsTable <<table>> #White {
    +id: uuid
    +identifier: text
    +value: text
    +expiresAt: timestamp
  }
}

package "Catalog & Scenario" {
  class categoriesTable <<table>> #White {
    +id: integer
    +name: varchar(100)
    +deletedAt: timestamp?
  }

  class scriptsTable <<table>> #White {
    +id: uuid
    +categoryId: integer?
    +expertId: uuid
    +title: varchar(150)
    +isDraft: boolean
    +draftOverAt: timestamp?
    +deletedAt: timestamp?
  }

  class criteriaTypesTable <<table>> #White {
    +id: integer
    +name: varchar(50)
  }

  class scriptCriteriaTable <<table>> #White {
    +id: uuid
    +scriptId: uuid
    +typeId: integer
    +content: text
    +deletedAt: timestamp?
  }

  class questionTemplatesTable <<table>> #White {
    +id: uuid
    +scriptId: uuid
    +order: integer
    +text: text
    +deletedAt: timestamp?
  }

  class specificCriteriaTable <<table>> #White {
    +id: uuid
    +questionId: uuid
    +content: text
  }
}

package "Interview" {
  class interviewSessionsTable <<table>> #White {
    +id: uuid
    +userId: uuid
    +scriptId: uuid
    +finalScore: integer?
    +expertFeedback: text?
    +currentQuestionIndex: integer
    +startedAt: timestamp
    +summarize: text?
  }

  class interviewSessionStatusesTable <<table>> #White {
    +id: integer
    +name: varchar(20)
  }

  class interviewSessionStatusLogTable <<table>> #White {
    +id: uuid
    +sessionId: uuid
    +statusId: integer
    +createdAt: timestamp
  }

  class chatMessagesTable <<table>> #White {
    +id: uuid
    +sessionId: uuid
    +isAi: boolean
    +messageText: text
    +analysisNote: text?
    +createdAt: timestamp
  }
}

package "Reputation & Moderation" {
  class achievementsTable <<table>> #White {
    +id: uuid
    +name: varchar(100)
    +description: text
    +formula: text
  }

  class userAchievementsTable <<table>> #White {
    +userId: uuid
    +achievementId: uuid
    +awardedAt: timestamp
  }

  class reportsTable <<table>> #White {
    +id: uuid
    +reporterId: uuid
    +scriptId: uuid
    +reason: text
  }

  class reportStatusesTable <<table>> #White {
    +id: integer
    +name: varchar(20)
  }

  class reportStatusLogTable <<table>> #White {
    +id: uuid
    +reportId: uuid
    +statusId: integer
    +createdAt: timestamp
  }
}

rolesTable "1" <-- "0..*" usersTable : role
usersTable "1" <-- "0..*" accountsTable : user
usersTable "1" <-- "0..*" sessionsTable : user

categoriesTable "1" <-- "0..*" scriptsTable : category
usersTable "1" <-- "0..*" scriptsTable : expert
scriptsTable "1" <-- "0..*" scriptCriteriaTable : globalCriteria
criteriaTypesTable "1" <-- "0..*" scriptCriteriaTable : type
scriptsTable "1" <-- "0..*" questionTemplatesTable : questions
questionTemplatesTable "1" <-- "0..*" specificCriteriaTable : specificCriteria

usersTable "1" <-- "0..*" interviewSessionsTable : user
scriptsTable "1" <-- "0..*" interviewSessionsTable : script
interviewSessionsTable "1" <-- "0..*" chatMessagesTable : messages
interviewSessionsTable "1" <-- "0..*" interviewSessionStatusLogTable : statusLogs
interviewSessionStatusesTable "1" <-- "0..*" interviewSessionStatusLogTable : status

usersTable "1" <-- "0..*" userAchievementsTable : user
achievementsTable "1" <-- "0..*" userAchievementsTable : achievement
usersTable "1" <-- "0..*" reportsTable : reporter
scriptsTable "1" <-- "0..*" reportsTable : scenario
reportsTable "1" <-- "0..*" reportStatusLogTable : statusLogs
reportStatusesTable "1" <-- "0..*" reportStatusLogTable : status

@enduml
