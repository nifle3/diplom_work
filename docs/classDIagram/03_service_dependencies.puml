@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam backgroundColor White
hide circle

title Application Service Composition

package "API bootstrap" {
  class AppDependencies <<type>> #White {
    +auth
    +db
    +file
    +llm
  }

  class defaultDependencies <<object>> #White {
    +auth
    +db
    +file
    +llm
  }

  class createContext <<function>> #White {
    +req
    +dependencies
    +session
    +requestId
    +clientIp
    +userAgent
    +setCookieHeaders
  }

  class Context <<type>> #White {
    +session
    +requestId
    +clientIp
    +userAgent
    +setCookieHeaders
  }
}

package "Auth" {
  class auth <<service>> #White {
  }
}

package "Database" {
  class db <<instance>> #White {
  }
}

package "File" {
  class file <<module>> #White {
  }
}

package "LLM" {
  class llm <<module>> #White {
  }
}

defaultDependencies ..> auth
defaultDependencies ..> db
defaultDependencies ..> file
defaultDependencies ..> llm
defaultDependencies ..|> AppDependencies

createContext ..> AppDependencies
createContext ..> defaultDependencies : fallback
createContext ..> auth : getSession()
createContext ..> Context

@enduml
