@startuml Conceptual DB Diagram

skinparam linetype ortho
skinparam entity {
  BackgroundColor White
  BorderColor #555
  FontSize 12
}

entity "Пользователь" {
  имя
  email
  роль
  XP
}

entity "Категория" {
  название
}

entity "Сценарий" {
  название
  описание
  контекст
}

entity "Вопрос" {
  текст
}

entity "Критерий сценария" {
  содержание
  тип
}

entity "Критерий вопроса" {
  содержание
}

entity "Сессия интервью"

entity "Сообщение" {
  текст
}

entity "Достижение" {
  название
  описание
}

entity "Жалоба" {
  причина
}

' Relations
"Пользователь" ||--o{ "Сценарий" : "создаёт (как эксперт)"
"Пользователь" ||--o{ "Сессия интервью" : "проходит"
"Пользователь" }o--o{ "Достижение" : "получает"
"Пользователь" ||--o{ "Жалоба" : "подаёт"

"Категория" ||--o{ "Сценарий" : "классифицирует"

"Сценарий" ||--o{ "Вопрос" : "содержит"
"Сценарий" ||--o{ "Критерий сценария" : "имеет"
"Сценарий" ||--o{ "Сессия интервью" : "используется в"
"Сценарий" ||--o{ "Жалоба" : "является предметом"

"Вопрос" ||--o{ "Критерий вопроса" : "имеет"

"Сессия интервью" ||--o{ "Сообщение" : "содержит"

@enduml
