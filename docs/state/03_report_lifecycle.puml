@startuml 03_report_lifecycle
title Жизненный цикл жалобы

hide empty description
skinparam state {
  BackgroundColor White
  BorderColor #333333
}

[*] --> New : создать()

state "Новая" as New

state "На рассмотрении" as InReview

state "Решена" as Resolved

state "Отклонена" as Rejected

New --> InReview : сменить статус администратором()
New --> Resolved : сменить статус администратором()
New --> Rejected : сменить статус администратором()

InReview --> New : сменить статус администратором()
InReview --> Resolved : сменить статус администратором()
InReview --> Rejected : сменить статус администратором()

Resolved --> New : сменить статус администратором()
Resolved --> InReview : сменить статус администратором()
Resolved --> Rejected : сменить статус администратором()

Rejected --> New : сменить статус администратором()
Rejected --> InReview : сменить статус администратором()
Rejected --> Resolved : сменить статус администратором()

@enduml
