@startuml 04_sandbox_session_state
title Операционное состояние sandbox-сессии эксперта

hide empty description
skinparam state {
  BackgroundColor White
  BorderColor #333333
}

[*] --> Ready : createSession()

state "Готова" as Ready

Ready --> AwaitingAnswer : first question shown

state "Ожидание ответа" as AwaitingAnswer

AwaitingAnswer --> Evaluating : sendAnswer()

state "Проверка" as Evaluating

Evaluating --> AwaitingAnswer : decision = next_topic / follow_up
Evaluating --> Finished : decision = finish

state "Завершена" as Finished

AwaitingAnswer --> Rewinding : rewindSession()

state "Перемотка" as Rewinding

Rewinding --> AwaitingAnswer : restore messages

Finished --> [*]

@enduml
