@startuml 04_sandbox_session_state
title Операционное состояние sandbox-сессии эксперта

hide empty description
skinparam state {
  BackgroundColor White
  BorderColor #333333
}

[*] --> Ready : создать сессию()

state "Готова" as Ready

Ready --> AwaitingAnswer : показан первый вопрос

state "Ожидание ответа" as AwaitingAnswer

AwaitingAnswer --> Evaluating : отправить ответ()

state "Проверка" as Evaluating

Evaluating --> AwaitingAnswer : решение = следующая тема / уточнение
Evaluating --> Finished : решение = завершить

state "Завершена" as Finished

AwaitingAnswer --> Rewinding : перемотать сессию()

state "Перемотка" as Rewinding

Rewinding --> AwaitingAnswer : восстановить сообщения

Finished --> [*]

@enduml
