@startuml 02_interview_session_lifecycle
title Жизненный цикл интервью-сессии

hide empty description
skinparam state {
  BackgroundColor White
  BorderColor #333333
}

[*] --> Active : createNewSession()

state "Активна" as Active

Active --> Active : addNewMessage()\nnext question / follow-up
Active --> Complete : finalizeSession()\nfinish branch
Active --> Canceled : cancelSession()

state "Завершена" as Complete

state "Отменена" as Canceled

Complete --> Complete : повторный finalizeSession()\nno-op
Canceled --> Canceled : повторный cancelSession()\nno-op

Complete --> [*]
Canceled --> [*]

@enduml
