@startuml 01_script_lifecycle
title Жизненный цикл сценария

hide empty description

[*] --> Draft : createNewDraft

state Draft

note right of Draft
  isDraft = true
  Сценарий редактируется
  и не виден в каталоге
end note

Draft --> Published : mutateThirdStep()\npostDraft()

state Published

note right of Published
  isDraft = false
  postDraft() дополнительно
  фиксирует draftOverAt
end note

Draft --> Deleted : deleteScript()
Published --> Deleted : deleteScript()

state Deleted

note right of Deleted
  deletedAt = now()
  Мягкое удаление
end note

Deleted --> [*]

note bottom
  В коде публикация может прийти
  либо через финальный шаг мастера,
  либо через отдельный `postDraft()`.
end note

@enduml
