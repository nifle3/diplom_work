@startuml 01_script_lifecycle
title Жизненный цикл сценария

hide empty description
skinparam state {
  BackgroundColor White
  BorderColor #333333
}

[*] --> Draft : создать черновик

state "Черновик" as Draft

Draft --> Published : изменить третий шаг()\nопубликовать()

state "Опубликован" as Published

Draft --> Deleted : удалить сценарий()
Published --> Deleted : удалить сценарий()

state "Удалён" as Deleted

Deleted --> [*]

@enduml
