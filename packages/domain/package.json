{
	"name": "@diplom_work/domain",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./error": {
			"default": "./src/error/index.ts"
		},
		"./values/*": {
			"default": "./src/values/*.ts"
		}
	},
	"scripts": {
		"test": "vitest run --config ../../packages/config/vitest.config.ts",
		"test:coverage": "vitest run --coverage --config ../../packages/config/vitest.config.ts",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {},
	"devDependencies": {
		"@diplom_work/config": "workspace:*",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
